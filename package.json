{
  "name": "hour-launcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "init-config": "tsx src/cli/index.ts init-config",
    "install:browsers": "playwright install chromium",
    "launch": "tsx src/cli/index.ts launch",
    "repair": "tsx src/cli/index.ts repair",
    "setup-scheduler": "tsx scripts/setup-scheduler.ts install",
    "remove-scheduler": "tsx scripts/setup-scheduler.ts remove"
  },
  "dependencies": {
    "@playwright/test": "^1.44.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
